#include "Arduino.h"

#include "FS.h"
#include "SD.h"
#include "SPI.h"
// ===== HSPI PINS =====
#define HSPI_SCK 40
#define HSPI_MISO 42
#define HSPI_MOSI 41
#define SD_CS 39

#include "FS.h"
#include "SD.h"
#include "SPI.h"

SPIClass *hspi = NULL;

// ======================
// ======================
void listDir(fs::FS &fs, const char *dirname, uint8_t levels) {

  Serial.printf("\nListing: %s\n", dirname);

  File root = fs.open(dirname);
  if (!root || !root.isDirectory()) {
    Serial.println("Open dir failed");
    return;
  }

  File file = root.openNextFile();
  while (file) {

    String fullPath = String(dirname);
    if (!fullPath.endsWith("/")) fullPath += "/";
    fullPath += file.name();

    if (file.isDirectory()) {
      Serial.print("  DIR : ");
      Serial.println(file.name());

      if (levels) {
        listDir(fs, fullPath.c_str(), levels - 1);
      }
    } else {
      Serial.print("  FILE: ");
      Serial.print(file.name());
      Serial.print("  SIZE: ");
      Serial.println(file.size());
    }

    file = root.openNextFile();
  }
}

// ======================
// SIMPLE WRITE TEST
// ======================
void writeTest() {
  File f = SD.open("/hello.txt", FILE_WRITE);
  if (f) {
    f.println("Hello ESP32-S3");
    f.close();
    Serial.println("Write OK");
  } else {
    Serial.println("Write Failed");
  }
}

// ======================
// SETUP
// ======================
void setup() {

  Serial.begin(115200);
  delay(1500);   // cho monitor bắt kịp

  Serial.println("\nBooting...");

  hspi = new SPIClass(HSPI);
  hspi->begin(HSPI_SCK, HSPI_MISO, HSPI_MOSI, SD_CS);

  Serial.println("Mounting SD...");

  if (!SD.begin(SD_CS, *hspi, 10000000)) {
    Serial.println("Card Mount Failed!");
  } else {
    Serial.println("SD Mount OK");
  }

  if (SD.cardType() == CARD_NONE) {
    Serial.println("No SD card detected");
    return;
  }

  Serial.print("Card Size: ");
  Serial.print(SD.cardSize() / (1024 * 1024));
  Serial.println(" MB");

  listDir(SD, "/", 1);

  writeTest();

  Serial.println("Done setup.");
}

void loop() {
  static uint32_t t = 0;
  if (millis() - t > 3000) {
    t = millis();
    Serial.println("Alive...");
  }
}
